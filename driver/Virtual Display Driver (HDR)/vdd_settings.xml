<?xml version='1.0' encoding='utf-8'?>
<!-- WiFi Display - Single 1080p@60 Virtual Monitor -->
<vdd_settings>

    <monitors>
        <count>1</count>
    </monitors>

    <gpu>
        <friendlyname>default</friendlyname>
    </gpu>

    <global>
        <g_refresh_rate>60</g_refresh_rate>
    </global>

    <resolutions>
        <resolution>
            <width>1920</width>
            <height>1080</height>
            <refresh_rate>60</refresh_rate>
        </resolution>
    </resolutions>

    <logging>
        <SendLogsThroughPipe>true</SendLogsThroughPipe>
        <logging>false</logging>
        <debuglogging>false</debuglogging>
    </logging>

    <colour>
        <SDR10bit>false</SDR10bit>
        <HDRPlus>false</HDRPlus>
        <ColourFormat>RGB</ColourFormat>
    </colour>

    <cursor>
        <HardwareCursor>true</HardwareCursor>
        <CursorMaxX>128</CursorMaxX>
        <CursorMaxY>128</CursorMaxY>
        <AlphaCursorSupport>true</AlphaCursorSupport>
    </cursor>

    <edid>
        <CustomEdid>false</CustomEdid>
        <PreventSpoof>false</PreventSpoof>
        <EdidCeaOverride>false</EdidCeaOverride>
    </edid>

    <edid_integration>
        <enabled>false</enabled>
    </edid_integration>

    <hdr_advanced>
        <hdr10_static_metadata>
            <enabled>false</enabled>
        </hdr10_static_metadata>
        <color_primaries>
            <enabled>false</enabled>
        </color_primaries>
        <color_space>
            <enabled>false</enabled>
        </color_space>
    </hdr_advanced>

    <auto_resolutions>
        <enabled>false</enabled>
    </auto_resolutions>

    <color_advanced>
        <bit_depth_management>
            <auto_select_from_color_space>false</auto_select_from_color_space>
            <force_bit_depth>8</force_bit_depth>
            <fp16_surface_support>false</fp16_surface_support>
        </bit_depth_management>
    </color_advanced>

</vdd_settings>
